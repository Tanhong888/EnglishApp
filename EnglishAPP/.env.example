APP_ENV=dev
APP_NAME=EnglishAPP

# Backend
API_PORT=8000

# Quick local bootstrap
DATABASE_URL=sqlite:///./backend/englishapp.db

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/englishapp

REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=change_me_to_a_32_char_minimum_secret_key_2026
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=14

# Optional observability/security toggles
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SECURITY_HSTS_ENABLED=false
